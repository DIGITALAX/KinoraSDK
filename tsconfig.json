{
  "compilerOptions": {
    "module": "commonjs",
    "jsx": "react",
    "target": "ES2020",
    "esModuleInterop": true,
    "declaration": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": false,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },
    "incremental": true,
    "resolveJsonModule": true,
    "typeRoots": ["src/@types", "node_modules/@types"],
    "types": ["node", "jest", "mocha"],
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*", "test"],
  "exclude": ["node_modules", "lib", "**/*spec.ts"],
  "files": ["./hardhat.config.ts", "./scripts/deploy.ts", "test"],
}
