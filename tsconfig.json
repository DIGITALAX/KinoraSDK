{
  "compilerOptions": {
    "module": "commonjs",
    "jsx": "react",
    "target": "ES2020",
    "esModuleInterop": true,
    "declaration": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": false,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "resolveJsonModule": true,
    "typeRoots": ["src/@types", "node_modules/@types"],
    "types": ["node", "mocha"],
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "files": ["src/index.ts"],
  // "include": ["src/**/*", "./hardhat.config.ts", "./scripts/deploy.ts", "./test/**/*.ts"],
  "include": ["src/**/*"],
  // "exclude": ["node_modules", "lib", "**/*spec.ts"],
  "exclude": ["node_modules"]
}
