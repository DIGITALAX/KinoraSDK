{
  "name": "kinora-sdk",
  "version": "0.0.2",
  "description": "An open source typescript SDK, compatible with node and browser, for instantiating and automating encrypted on-chain Quests with video social Livepeer metrics.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "demo": "npm run yalc-clean && npm run dev",
    "yalc-clean": "cd demo && yalc remove kinora-sdk && cd .. && yalc installations clean kinora-sdk && rm -rf dist && npm run build && yalc publish --replace && cd demo && yalc add kinora-sdk && cd ..",
    "copy-env": "awk -F '=' '{ print \"REACT_APP_\" $1 \"=\" $2 }' .env > demo/.env",
    "install-demo": "cd demo && rm -rf node_modules package-lock.json .env && npm install && cd ..",
    "start-demo": "cd demo && npm run start",
    "dev": "npm run install-demo && npm run copy-env && npm run start-demo",
    "build": "node --trace-deprecation node_modules/.bin/webpack",
    "start": "node dist/index.js",
    "test": "npx hardhat test --typecheck"
  },
  "directories": {
    "test": "test"
  },
  "devDependencies": {
    "@ethersproject/abi": "^5.7.0",
    "@ethersproject/providers": "^5.7.2",
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.4",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.6",
    "@nomicfoundation/hardhat-toolbox": "^2.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.1",
    "@nomiclabs/hardhat-etherscan": "^3.1.2",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "@openzeppelin/contracts": "^4.8.0",
    "@testing-library/react": "^14.0.0",
    "@types/bs58": "^4.0.1",
    "@types/chai": "^4.3.6",
    "@types/crypto-js": "^4.1.2",
    "@types/express": "^4.17.17",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.6.0",
    "@types/uuid": "^9.0.6",
    "chai": "^4.3.8",
    "clean-webpack-plugin": "^4.0.0",
    "dotenv-webpack": "^8.0.1",
    "hardhat": "^2.17.2",
    "hardhat-gas-reporter": "^1.0.9",
    "mocha": "^10.2.0",
    "siwe": "^2.1.4",
    "source-map-loader": "^4.0.1",
    "terser-webpack-plugin": "^5.3.9",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@apollo/client": "^3.8.3",
    "@lit-protocol/lit-auth-client": "3.0.5",
    "@lit-protocol/lit-node-client": "3.0.5",
    "@lit-protocol/pkp-ethers": "3.0.5",
    "@typechain/hardhat": "^6.1.4",
    "assert": "^2.1.0",
    "axios": "^1.5.0",
    "browserify-zlib": "^0.2.0",
    "bs58": "^5.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "graphql": "^16.8.1",
    "https-browserify": "^1.0.0",
    "kinora-sdk": "file:.yalc/kinora-sdk",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "ts-loader": "^9.4.4",
    "tty-browserify": "^0.0.1",
    "typechain": "^8.1.1",
    "uuid": "^9.0.1"
  },
  "peerDependencies": {
    "@types/react": "^18.2.23",
    "react": "^18.2.0"
  }
}
