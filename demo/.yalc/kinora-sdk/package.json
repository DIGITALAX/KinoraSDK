{
  "name": "kinora-sdk",
  "version": "0.0.2",
  "description": "An open source typescript SDK, compatible with node and browser, for instantiating and automating encrypted on-chain Quests with video social LivePeer metrics.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "copy-env": "awk -F '=' '{ print \"REACT_APP_\" $1 \"=\" $2 }' .env > demo/.env",
    "install-demo": "cd demo && rm -rf node_modules package-lock.json .env && npm install",
    "start-demo": "cd demo && npm run start",
    "dev": "npm run install-demo && npm run copy-env && npm run start-demo",
    "build": "node --trace-deprecation node_modules/.bin/webpack",
    "start": "node dist/index.js",
    "test": "npx hardhat test --typecheck"
  },
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "@apollo/client": "^3.8.3",
    "@lit-protocol/lit-auth-client": "^2.2.49",
    "@lit-protocol/lit-node-client": "^2.2.50",
    "@lit-protocol/pkp-ethers": "^2.2.50",
    "@typechain/hardhat": "^6.1.4",
    "assert": "^2.1.0",
    "axios": "^1.5.0",
    "browserify-zlib": "^0.2.0",
    "bs58": "^5.0.0",
    "crypto-browserify": "^3.12.0",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "https-browserify": "^1.0.0",
    "ipfs-http-client": "56.0.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "siwe": "2.1.3",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "ts-loader": "^9.4.4",
    "tty-browserify": "^0.0.1",
    "typechain": "^8.1.1"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "@types/react": "^18.2.23"
  },
  "yalcSig": "4d0489a0d5eb8463b4eb64943a1b1e07"
}
